<style>
	:root {
		--footer-bg: #3b5c8c;
		--footer-bg-2: #2f4b73;
		--footer-text: rgba(255, 255, 255, 0.9);
		--footer-muted: rgba(255, 255, 255, 0.7);
		--brand-sun: #e3c21c;
		--brand-gold: #c9a33c;
		--brand-sky: #70b3e0;
		--brand-sky-2: #47a2df;
	}
	.footer {
		background: linear-gradient(
			180deg,
			var(--footer-bg) 0%,
			var(--footer-bg-2) 100%
		);
		color: var(--footer-text);
		padding: 4rem 1.5rem 1rem;
		font-family: sans-serif;
		margin-top: 3rem;
	}

	.footer-container {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 2rem;
		max-width: 1200px;
		margin: 0 auto;
	}

	.footer-logo {
		flex: 1 1 250px;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.5rem;
	}

	.footer-logo img {
		width: 120px;
		height: auto;
		border-radius: 50%;
	}

	.footer-logo p {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.4;
	}

	.footer-icon {
		height: 30px;
	}

	.footer-links,
	.footer-contact,
	.footer-social {
		flex: 1 1 200px;
	}

	.footer-links h4,
	.footer-contact h4,
	.footer-social h4 {
		margin-bottom: 1rem;
		font-size: 1.1rem;
		color: var(--brand-sun);
		letter-spacing: 0.2px;
	}

	.footer-links ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.footer-links li {
		margin-bottom: 0.55rem;
	}

	.footer-links a,
	.footer-contact a {
		color: var(--footer-text);
		text-decoration: none;
		transition:
			color 0.2s ease,
			opacity 0.2s ease;
	}

	.footer-links a:hover,
	.footer-contact a:hover {
		color: var(--brand-sun);
	}

	.footer-contact p {
		margin: 0.4rem 0;
		font-size: 0.95rem;
		color: var(--footer-muted);
	}

	.social-icons a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		margin-right: 0.6rem;
		border-radius: 10px;
		padding: 6px;
		transition:
			transform 0.2s ease,
			background 0.2s ease;
	}

	.social-icons a:hover {
		transform: translateY(-2px);
		background: rgbs(255, 255, 255, 0.08);
	}

	.footer-bottom {
		text-align: center;
		margin-top: 2rem;
		font-size: 0.85rem;
		border-top: 1px solid rgba(201, 163, 60, 0.55);
		padding-top: 1rem;
		color: var(--brand-sky);
		transition: color 0.2s ease;
	}

	.footer-bottom a:hover {
		color: var(--brand-sky-2);
	}
</style>
