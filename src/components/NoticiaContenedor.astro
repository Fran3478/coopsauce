---
import NovedadesCarousel from "./NovedadesCarousel.astro";
import NoticiasSidebar from "./NoticiasList.astro";

interface Item {
	slug: string;
	title: string;
	imageUrl?: string;
	date?: string;
	category?: string;
	kind?: "noticia" | "novedad";
	externalUrl?: string;
}

const { novedades = [], noticias = [] } = Astro.props as {
	novedades: Item[];
	noticias: Item[];
};
---

<div
	class="noticias-y-blog"
	class:list={{ "is-empty": novedades.length === 0 }}
	data-has-carousel={false}
>
	<!-- <NovedadesCarousel novedades={novedades} /> -->
	<NoticiasSidebar noticias={noticias} />
</div>

<style>
	.noticias-y-blog {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1rem;
		align-items: start;
	}

	.noticias-y-blog[data-has-carousel="true"] {
		grid-template-columns: 1.8fr 1fr;
		max-width: 1400px;
	}

	@media (min-width: 1024px) {
		.noticias-y-blog {
			padding: 0 1.5rem;
		}
	}

	@media (max-width: 720px) {
		.noticias-y-blog {
			gap: 1.25rem;
			padding: 0 0.75rem;
		}
	}

	.noticias-y-blog :global(.blog-sidebar) {
		max-width: none;
	}
</style>
