---
import Layout from "../layouts/Layout.astro";

export const prerender = false;
---

<Layout title="Misión y Visión">
	<main class="mv-page">
		<header class="mv-hero">
			<div class="mv-hero-inner">
				<p class="mv-kicker">Asociación Vecinal de Saneamiento Sauce</p>
				<h1>Misión y visión</h1>
				<p class="mv-lead">
					Nuestro propósito y el futuro que construimos con el trabajo
					de los vecinos.
				</p>
			</div>
		</header>

		<section class="mv-section" aria-label="Misión">
			<div class="mv-card">
				<div class="mv-head">
					<span class="mv-tag">Misión</span>
					<h2>Lo que hacemos cada día</h2>
				</div>

				<p class="mv-text">
					Garantizar el acceso equitativo, continuo y seguro al agua
					potable para todas las familias de Sauce, mediante la
					gestión comunitaria responsable, transparente y solidaria de
					los sistemas de captación, tratamiento y distribución de
					agua, cuidando el recurso hídrico y trabajando codo a codo
					con los vecinos para mejorar la calidad de vida y asegurar
					el acceso al recurso en nuestra querida localidad.
				</p>

				<ul class="mv-points" aria-label="Pilares de la misión">
					<li>Gestión comunitaria responsable y solidaria</li>
					<li>Transparencia en cada decisión</li>
					<li>Cuidado del recurso y del entorno</li>
					<li>Trabajo conjunto con los vecinos</li>
				</ul>
			</div>
		</section>

		<section class="mv-section" aria-label="Visión">
			<div class="mv-card">
				<div class="mv-head">
					<span class="mv-tag is-gold">Visión</span>
					<h2>El futuro que queremos</h2>
				</div>

				<p class="mv-text">
					Ser reconocida como una asociación vecinal modelo en la
					provincia de Corrientes, donde cada hogar de Sauce cuente
					con agua potable de calidad las 24 horas, con redes de
					distribución que protejan nuestra salud y el medio ambiente,
					gestionada 100% por los propios vecinos con transparencia
					total y tecnología adecuada a la economía de la comunidad.
					Un Sauce donde el agua sea motivo de orgullo y unión
					vecinal, y no de preocupación diaria.
				</p>

				<blockquote class="mv-quote">
					<p>
						Un Sauce donde el agua sea motivo de orgullo y unión
						vecinal, y no de preocupación diaria.
					</p>
				</blockquote>
			</div>
		</section>

		<section class="mv-cta" aria-label="Participación vecinal">
			<div class="mv-cta-inner">
				<div>
					<h3>Sumate a construir este futuro</h3>
					<p>
						La gestión vecinal se fortalece con participación.
						acercate, proponé ideas y ayudanos a mejorar el
						servicio.
					</p>
				</div>

				<div class="mv-actions">
					<a class="mv-btn primary" href="/contacto">Contacto</a>
					<a class="mv-btn ghost" href="/">Volver al inicio</a>
				</div>
			</div>
		</section>
	</main>

	<style>
		:root {
			--brand-blue: #3b5c8c;
			--brand-blue-dark: #2f4b73;
			--brand-sun: #e3c21c;
			--brand-gold: #c9a33c;

			--ink: #0f172a;
			--muted: rgba(15, 23, 42, 0.7);
			--bg: #f7f8fb;
			--surface: #ffffff;
			--border: rgba(15, 23, 42, 0.08);
		}

		.mv-page {
			padding-top: 120px;
			background: linear-gradient(180deg, #ffffff 0%, var(--bg) 100%);
			min-height: 100vh;
		}

		/* HERO (igual lenguaje que historia) */
		.mv-hero {
			max-width: 1100px;
			margin: 0 auto;
			padding: 2rem 1rem 1rem;
		}

		.mv-hero-inner {
			background: linear-gradient(
				180deg,
				rgba(59, 92, 140, 0.12) 0%,
				rgba(255, 255, 255, 0.8) 100%
			);
			border-radius: 20px;
			padding: 2rem;
			border: 1px solid var(--border);
		}

		.mv-kicker {
			margin: 0 0 0.35rem;
			color: rgba(47, 75, 115, 0.9);
			font-weight: 900;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			font-size: 0.78rem;
		}

		.mv-hero h1 {
			margin: 0.5rem 0;
			font-size: 2.6rem;
			color: var(--brand-blue-dark);
			letter-spacing: -0.02em;
		}

		.mv-lead {
			margin: 0.35rem 0 0;
			max-width: 70ch;
			color: var(--muted);
			line-height: 1.7;
		}

		/* SECTIONS */
		.mv-section {
			max-width: 900px;
			margin: 0 auto;
			padding: 1.25rem 1rem;
		}

		.mv-card {
			background: var(--surface);
			border: 1px solid var(--border);
			border-radius: 18px;
			padding: 1.5rem;
		}

		.mv-head {
			display: grid;
			gap: 0.5rem;
			margin-bottom: 0.75rem;
		}

		.mv-tag {
			width: fit-content;
			padding: 0.28rem 0.6rem;
			border-radius: 999px;
			background: rgba(47, 75, 115, 0.09);
			border: 1px solid rgba(47, 75, 115, 0.18);
			color: var(--brand-blue-dark);
			font-weight: 900;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			font-size: 0.72rem;
		}

		.mv-tag.is-gold {
			background: rgba(201, 163, 60, 0.12);
			border-color: rgba(201, 163, 60, 0.28);
			color: rgba(47, 75, 115, 0.95);
		}

		.mv-card h2 {
			margin: 0;
			color: var(--ink);
			font-weight: 900;
			letter-spacing: -0.01em;
			font-size: 1.25rem;
		}

		.mv-text {
			margin: 0;
			color: var(--muted);
			line-height: 1.75;
		}

		.mv-points {
			margin: 1rem 0 0;
			padding: 0;
			list-style: none;
			display: grid;
			gap: 0.55rem;
		}

		.mv-points li {
			display: flex;
			gap: 0.6rem;
			align-items: flex-start;
			color: rgba(15, 23, 42, 0.78);
			line-height: 1.6;
			font-weight: 650;
		}

		.mv-points li::before {
			content: "";
			margin-top: 0.45rem;
			width: 9px;
			height: 9px;
			border-radius: 999px;
			background: linear-gradient(
				180deg,
				var(--brand-sun) 0%,
				var(--brand-gold) 100%
			);
			flex: 0 0 9px;
		}

		.mv-quote {
			margin: 1rem 0 0;
			padding: 1rem 1rem 0.95rem;
			border-left: 4px solid rgba(201, 163, 60, 0.8);
			background: rgba(15, 23, 42, 0.03);
			border-radius: 12px;
		}

		.mv-quote p {
			margin: 0;
			color: rgba(15, 23, 42, 0.8);
			font-weight: 800;
			line-height: 1.6;
		}

		/* CTA */
		.mv-cta {
			max-width: 900px;
			margin: 0 auto;
			padding: 0.75rem 1rem 2.5rem;
		}

		.mv-cta-inner {
			border-radius: 18px;
			padding: 1.25rem 1.5rem;
			border: 1px solid var(--border);
			background: linear-gradient(
				180deg,
				rgba(59, 92, 140, 0.08) 0%,
				rgba(255, 255, 255, 0.9) 100%
			);

			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 1rem;
		}

		.mv-cta-inner h3 {
			margin: 0;
			color: var(--brand-blue-dark);
			font-weight: 900;
			letter-spacing: -0.01em;
			font-size: 1.15rem;
		}

		.mv-cta-inner p {
			margin: 0.35rem 0 0;
			color: var(--muted);
			line-height: 1.6;
			max-width: 70ch;
		}

		.mv-actions {
			display: flex;
			gap: 0.6rem;
			flex-wrap: wrap;
			justify-content: flex-end;
		}

		.mv-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 0.65rem 1.05rem;
			border-radius: 999px;
			font-weight: 900;
			text-decoration: none;
			letter-spacing: 0.02em;
			transition:
				transform 0.12s ease,
				filter 0.12s ease,
				background 0.12s ease,
				border-color 0.12s ease;
		}

		.mv-btn.primary {
			color: #fff;
			background: linear-gradient(
				180deg,
				var(--brand-blue) 0%,
				var(--brand-blue-dark) 100%
			);
			border: 2px solid rgba(201, 163, 60, 0);
		}

		.mv-btn.primary:hover {
			transform: translateY(-1px);
			filter: brightness(0.98);
			border-color: rgba(201, 163, 60, 0.55);
		}

		.mv-btn.ghost {
			color: var(--brand-blue-dark);
			background: rgba(255, 255, 255, 0.9);
			border: 1px solid rgba(15, 23, 42, 0.12);
		}

		.mv-btn.ghost:hover {
			transform: translateY(-1px);
			background: #fff;
		}

		.mv-btn:focus-visible {
			outline: 3px solid rgba(227, 194, 28, 0.65);
			outline-offset: 4px;
		}

		/* RESPONSIVE */
		@media (max-width: 920px) {
			.mv-page {
				padding-top: 104px;
			}
		}

		@media (max-width: 860px) {
			.mv-cta-inner {
				flex-direction: column;
				align-items: flex-start;
			}
			.mv-actions {
				width: 100%;
				justify-content: flex-start;
			}
		}

		@media (max-width: 520px) {
			.mv-hero-inner,
			.mv-card,
			.mv-cta-inner {
				padding: 1rem;
				border-radius: 16px;
			}
			.mv-btn {
				width: 100%;
			}
		}
	</style>
</Layout>
